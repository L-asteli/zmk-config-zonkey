#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,input-split = &input_split;
    };

    input_split: input_split@0 {
        compatible = "zmk,input-split";
        reg = <0>;
        status = "okay";
    };

    trackball_listener: trackball_listener {
        compatible = "zmk,input-listener";
        status = "disabled";
    };
};